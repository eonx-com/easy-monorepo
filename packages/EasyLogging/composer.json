{
    "name": "eonx-com/easy-logging",
    "description": "Create and configure Monolog Loggers easily",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "eonx-com/easy-utils": "^6.23",
        "monolog/monolog": "^3.9",
        "symfony/config": "^7.2",
        "symfony/dependency-injection": "^7.2",
        "symfony/http-kernel": "^7.2",
        "symfony/service-contracts": "^3.5"
    },
    "require-dev": {
        "bugsnag/bugsnag": "^3.29",
        "eonx-com/easy-test": "^6.23",
        "laravel/lumen-framework": "^11.0",
        "phpunit/phpunit": "^10.5.63|^11.5.50|^12.5.8",
        "symfony/monolog-bundle": "^3.11.1"
    },
    "conflict": {
        "symfony/monolog-bundle": "<3.11.1"
    },
    "autoload": {
        "psr-4": {
            "EonX\\EasyLogging\\": "src",
            "EonX\\EasyLogging\\Bundle\\": "bundle",
            "EonX\\EasyLogging\\Laravel\\": "laravel"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EonX\\EasyLogging\\Tests\\": "tests",
            "EonX\\EasyLogging\\Tests\\Unit\\": "tests/Unit/src",
            "EonX\\EasyLogging\\Tests\\Unit\\Bundle\\": "tests/Unit/bundle",
            "EonX\\EasyLogging\\Tests\\Unit\\Laravel\\": "tests/Unit/laravel"
        }
    },
    "suggest": {
        "bugsnag/bugsnag": "For Bugsnag integration",
        "symfony/monolog-bundle": "To use the symfony/monolog-bundle integration"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "6.23-dev"
        }
    }
}
