{
    "name": "eonx-com/easy-api-platform",
    "description": "Provides features for API Platform applications",
    "type": "symfony-bundle",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "doctrine/collections": "^1.7.2 || ^2.6",
        "doctrine/dbal": "^3.8 || ^4.4",
        "doctrine/orm": "^2.20 || ^3.6",
        "doctrine/persistence": "^3.3 || ^4.1",
        "nesbot/carbon": "^3.8.4",
        "psr/log": "^3.0",
        "symfony/config": "^7.4 || ^8.0",
        "symfony/dependency-injection": "^7.4 || ^8.0",
        "symfony/http-foundation": "^7.4 || ^8.0",
        "symfony/http-kernel": "^7.4 || ^8.0",
        "symfony/property-access": "^7.4 || ^8.0",
        "symfony/property-info": "^7.4 || ^8.0",
        "symfony/serializer": "^7.4 || ^8.0",
        "symfony/uid": "^7.4 || ^8.0"
    },
    "require-dev": {
        "api-platform/doctrine-common": "^4.3.17",
        "api-platform/doctrine-orm": "^4.3.17",
        "api-platform/documentation": "^4.3.17",
        "api-platform/http-cache": "^4.3.17",
        "api-platform/hydra": "^4.3.17",
        "api-platform/json-schema": "^4.3.17",
        "api-platform/jsonld": "^4.3.17",
        "api-platform/metadata": "^4.3.17",
        "api-platform/openapi": "^4.3.17",
        "api-platform/serializer": "^4.3.17",
        "api-platform/state": "^4.3.17",
        "api-platform/symfony": "^4.3.17",
        "api-platform/validator": "^4.3.17",
        "doctrine/doctrine-bundle": "^2.12 || ^3.2",
        "eonx-com/easy-bugsnag": "^6.21",
        "eonx-com/easy-error-handler": "^6.21",
        "eonx-com/easy-test": "^6.21",
        "phpspec/prophecy-phpunit": "^2.0",
        "phpunit/phpunit": "^12.5|^13.0",
        "symfony/browser-kit": "^7.4 || ^8.0",
        "symfony/expression-language": "^7.4 || ^8.0",
        "symfony/framework-bundle": "^7.4 || ^8.0",
        "symfony/http-client": "^7.4 || ^8.0",
        "symfony/routing": "^7.4 || ^8.0",
        "symfony/runtime": "^7.4 || ^8.0",
        "symfony/security-bundle": "^7.4 || ^8.0",
        "symfony/twig-bundle": "^7.4 || ^8.0",
        "symfony/validator": "^7.4 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "EonX\\EasyApiPlatform\\": "src",
            "EonX\\EasyApiPlatform\\Bundle\\": "bundle"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EonX\\EasyApiPlatform\\Tests\\": "tests",
            "EonX\\EasyApiPlatform\\Tests\\Application\\": "tests/Application/src",
            "EonX\\EasyApiPlatform\\Tests\\Fixture\\App\\": "tests/Fixture/app/src",
            "EonX\\EasyApiPlatform\\Tests\\Unit\\": "tests/Unit/src"
        }
    },
    "suggest": {
        "api-platform/doctrine-orm": "To use Doctrine ORM related features (filters, pagination, state providers)",
        "api-platform/symfony": "To use this package in Symfony applications with API Platform",
        "eonx-com/easy-bugsnag": "To use EasyBugsnag integration",
        "eonx-com/easy-error-handler": "To use EasyErrorHandler integration",
        "symfony/validator": "To build validation error responses when EasyErrorHandler integration is enabled"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "6.21-dev"
        }
    }
}
