includes:
    - phpstan.neon

parameters:
    excludePaths:
        # @todo Remove when Doctrine DBAL 3 support is dropped.
        - %currentWorkingDirectory%/packages/EasyAsync/tests/Stub/Connection/BrokenDbal3Connection.php
        - %currentWorkingDirectory%/packages/EasyBugsnag/src/Doctrine/Connection/BreadcrumbLoggerDbal3Connection.php
        - %currentWorkingDirectory%/packages/EasyBugsnag/src/Doctrine/Statement/BreadcrumbLoggerDbal3Statement.php
        - %currentWorkingDirectory%/packages/EasySwoole/src/Doctrine/Connection/Dbal3Connection.php
        - %currentWorkingDirectory%/packages/EasySwoole/src/Doctrine/Driver/Dbal3Driver.php
        - %currentWorkingDirectory%/packages/EasySwoole/src/Doctrine/Factory/CoroutineConnectionDbal3Factory.php
        - %currentWorkingDirectory%/packages/EasySwoole/src/Doctrine/Statement/Dbal3Statement.php
    ignoreErrors:
        - message: '#Offset .* on array\{body\: string, headers\?\: array<string, string>\} on left side of \?\? always exists and is not nullable#'
          path: %currentWorkingDirectory%/packages/EasyAsync/src/Messenger/Serializer/MessageSerializer.php

        - message: '#Offset .* on array\{body\: string, headers\?\: array<string, string>\} on left side of \?\? always exists and is not nullable#'
          path: %currentWorkingDirectory%/packages/EasyEncryption/src/Encryptable/Serializer/EncryptableAwareMessengerSerializer.php

        - message: '#Call to function property_exists\(\) with EasyCorp\\Bundle\\EasyAdminBundle\\EventListener\\AdminRouterSubscriber and .* will always evaluate to true#'
          path: %currentWorkingDirectory%/packages/EasyServerless/src/EasyAdmin/Subscriber/ResetEasyAdminStateSubscriber.php

        - message: '#Call to function method_exists\(\) with Doctrine\\ORM\\Configuration and .* will always evaluate to true#'
          path: %currentWorkingDirectory%/packages/EasyPagination/tests/Unit/src/Paginator/AbstractDoctrineOrmPaginatorTestCase.php
